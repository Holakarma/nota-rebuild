// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum AuthProvider {
  PASSWORD
  TELEGRAM

  @@map("auth_provider")
}

enum NoteSourceType {
  WEB
  TELEGRAM

  @@map("note_source_type")
}

model User {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  login        String    @db.Text
  passwordHash String?   @map("password_hash") @db.Text
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  lastLoginAt  DateTime? @map("last_login_at") @db.Timestamptz(3)

  identities         AuthIdentity[]
  streams            Stream[]
  notes              Note[]
  sessions           Session[]
  telegramLinkTokens TelegramLinkToken[]

  @@map("users")
}

model AuthIdentity {
  id               String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String       @map("user_id") @db.Uuid
  provider         AuthProvider
  providerUserId   String       @map("provider_user_id") @db.Text
  providerUsername String?      @map("provider_username") @db.Text
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  lastUsedAt       DateTime?    @map("last_used_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId], map: "auth_identities_provider_provider_user_id_uq")
  @@unique([userId, provider], map: "auth_identities_user_id_provider_uq")
  @@index([userId], map: "auth_identities_user_id_idx")
  @@map("auth_identities")
}

model Stream {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  name           String   @db.Text
  normalizedName String   @map("normalized_name") @db.Text
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  noteStreams NoteStream[]

  @@unique([userId, normalizedName], map: "streams_user_id_normalized_name_uq")
  @@index([userId], map: "streams_user_id_idx")
  @@map("streams")
}

model Note {
  id           String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String                   @map("user_id") @db.Uuid
  bodyMarkdown String                   @map("body_markdown") @db.Text
  bodyText     String                   @map("body_text") @db.Text
  previewText  String                   @map("preview_text") @db.Text
  searchVector Unsupported("tsvector")? @map("search_vector")
  sourceType   NoteSourceType           @map("source_type")
  sourceMeta   Json                     @default("{}") @map("source_meta") @db.JsonB
  createdAt    DateTime                 @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime                 @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt    DateTime?                @map("deleted_at") @db.Timestamptz(3)

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  noteStreams NoteStream[]

  @@index([userId, updatedAt(sort: Desc)], map: "notes_user_id_updated_at_idx")
  @@map("notes")
}

model NoteStream {
  noteId    String   @map("note_id") @db.Uuid
  streamId  String   @map("stream_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  note   Note   @relation(fields: [noteId], references: [id], onDelete: Cascade)
  stream Stream @relation(fields: [streamId], references: [id], onDelete: Cascade)

  @@id([noteId, streamId], map: "note_streams_pkey")
  @@index([streamId, noteId], map: "note_streams_stream_id_note_id_idx")
  @@index([noteId, streamId], map: "note_streams_note_id_stream_id_idx")
  @@map("note_streams")
}

model Session {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  refreshTokenHash String    @unique(map: "sessions_refresh_token_hash_uq") @map("refresh_token_hash") @db.Text
  userAgent        String?   @map("user_agent") @db.Text
  ip               String?   @db.Text
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz(3)
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "sessions_user_id_idx")
  @@index([userId, expiresAt], map: "sessions_user_id_expires_at_idx")
  @@map("sessions")
}

model TelegramLinkToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique(map: "telegram_link_tokens_token_hash_uq") @map("token_hash") @db.Text
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(3)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(3)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "telegram_link_tokens_user_id_idx")
  @@index([expiresAt], map: "telegram_link_tokens_expires_at_idx")
  @@index([userId, usedAt], map: "telegram_link_tokens_user_id_used_at_idx")
  @@map("telegram_link_tokens")
}
